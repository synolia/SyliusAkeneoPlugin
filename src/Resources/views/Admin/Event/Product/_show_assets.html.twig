{% import '@SyliusUi/Macro/flags.html.twig' as flags %}

<div class="ui hidden divider"></div>

{% if akeneo_is_asset_enabled() and product is defined %}
<div id="assets">
    <h4 class="ui top attached large header">{{ 'sylius.ui.admin.akeneo.asset.listing_title'|trans }}</h4>
    <div class="ui attached segment">
        <div class="ui top attached tabular menu">
            {% set setLocales = [] %}
            {% for asset in product.assets %}
                {% if asset.locale not in setLocales %}
                    {% set localeCode = asset.locale %}
                    {% if asset.locale is not null  %}
                        <a class="item{% if loop.first %} active {% endif %}" {% if loop.first %}{{ sylius_test_html_attribute('active') }}{% endif %} data-tab="{{ localeCode|sylius_locale_name }}" {{ sylius_test_html_attribute('tab', localeCode|sylius_locale_name) }}>{{ flags.fromLocaleCode(localeCode)}} {{ localeCode|sylius_locale_name }}</a>
                    {% else %}
                        <a class="item{% if loop.first %} active {% endif %}" {% if loop.first %}{{ sylius_test_html_attribute('active') }}{% endif %} data-tab="{{ 'non-translatable' }}" {{ sylius_test_html_attribute('tab', 'non-translatable') }}><i class="globe icon"></i></a>
                    {% endif %}
                    {%  set setLocales = setLocales|merge([localeCode]) %}
                {% endif %}
            {% endfor %}
        </div>
        {% for locale in setLocales %}
            {% set data_tab = (locale is not null ? locale|sylius_locale_name : 'non-translatable') %}
            <div class="ui bottom attached tab segment{% if loop.first %} active{% endif %}" data-tab="{{ data_tab }}" {{ sylius_test_html_attribute('tab', data_tab) }}>
                <table class="ui very basic celled table fixed">
                    <thead>
                        <tr>
                            <th>{{ 'sylius.ui.admin.akeneo.asset.family_code'|trans }}</th>
                            <th>{{ 'sylius.ui.admin.akeneo.asset.asset_code'|trans }}</th>
                            <th>{{ 'sylius.ui.admin.akeneo.asset.attribute_code'|trans }}</th>
                            <th>{{ 'sylius.ui.admin.akeneo.asset.type'|trans }}</th>
                            <th>{{ 'sylius.ui.admin.akeneo.asset.content'|trans }}</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for asset in product.assets|filter(asset => asset.locale == locale) %}
                        <tr>
                            <td>{{ asset.familyCode }}</td>
                            <td>{{ asset.assetCode }}</td>
                            <td>{{ asset.attributeCode }}</td>
                            <td>{{ asset.type }}</td>
                            <td class="text" style="word-break: break-word">
                                {% include [
                                    '@SynoliaSyliusAkeneoPlugin/Admin/Event/Product/Asset/Types/'~asset.type~'.html.twig',
                                    '@SynoliaSyliusAkeneoPlugin/Admin/Event/Product/Asset/Types/default.html.twig'
                                ] with {
                                    'asset': asset,
                                    'locale': configuration.request.locale,
                                    'fallbackLocale': configuration.request.defaultLocale
                                } %}
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endfor %}
    </div>
</div>
{% endif %}
